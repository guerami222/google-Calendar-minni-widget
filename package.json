{
  "name": "gcal-widget",
  "version": "1.0.0",
  "description": "Tiny always-on-top Google Calendar widget",
  "main": "main.js",
  "author": "gueramii",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder --win"
  },
  "dependencies": {
    "google-auth-library": "^9.14.2",
    "googleapis": "^144.0.0",
    "node-ical": "^0.20.1"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.gueramii.gcalwidget",
    "productName": "Google Calendar Widget",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "styles.css",
      "package.json",
      "icon.ico",
      "credentials.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/electron/dist/ffmpeg.dll",
        "to": "ffmpeg.dll"
      }
    ],
    "asarUnpack": [
      "**/*.dll"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Google Calendar Widget"
    }
  }
}